# Variables de entorno por defecto
# Este archivo se usa directamente como .env en Docker/Compose.
# Para sobreescribir valores localmente, crea backend/.env con tus propios valores.

# Puerto en que escucha el servidor (las plataformas cloud lo inyectan automáticamente)
PORT=8080

# Host al que se enlaza el servidor
# Usar 0.0.0.0 para Docker/cloud; 127.0.0.1 solo para desarrollo local sin contenedor
HOST=0.0.0.0

# Activa el modo debug de Flask (solo para desarrollo local)
FLASK_DEBUG=false
